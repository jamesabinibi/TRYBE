{
  "name": "react-example",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "start": "NODE_ENV=production node dist/server.cjs",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --outfile=dist/server.cjs --external:express --external:vite --external:socket.io --external:nodemailer --external:axios --external:pg --external:bcryptjs --external:cloudinary --external:@aws-sdk/client-s3 --external:@google/genai --external:@supabase/supabase-js --external:dotenv --external:cors --external:ws --external:path --external:url --external:fs --external:http --external:crypto --sourcemap",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "cap:sync": "vite build && cap sync",
    "cap:open": "cap open android"
  },
